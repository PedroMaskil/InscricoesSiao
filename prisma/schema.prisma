// ─── Prisma Schema ────────────────────────────────────────
// Após qualquer alteração aqui, rode:
//   npx prisma migrate dev --name descricao-da-mudanca
// Para aplicar em produção:
//   npx prisma migrate deploy

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Registration {
  id              String    @id @default(uuid())
  name            String
  email           String
  phone           String
  cpf             String
  source          String?
  cep             String?
  city            String?
  isMember        Boolean   @default(false) @map("is_member")
  isOtherMember   Boolean   @default(false) @map("is_other_member")
  otherChurch     String?   @map("other_church")
  priceTier       String    @map("price_tier")
  amount          Int
  status          String    @default("pending")
  stripeSessionId String?   @map("stripe_session_id")
  paidAt          DateTime? @map("paid_at")
  checkedIn       Boolean   @default(false) @map("checked_in")
  checkedInAt     DateTime? @map("checked_in_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([status])
  @@index([isMember, status])
  @@map("registrations")
}

model Caravan {
  id           String    @id @default(uuid())
  city         String
  church       String
  leader       String
  leaderPhone  String    @map("leader_phone")
  peopleCount  Int       @map("people_count")
  listFileUrl  String?   @map("list_file_url")
  listFileName String?   @map("list_file_name")
  status       String    @default("confirmed")
  checkedIn    Boolean   @default(false) @map("checked_in")
  checkedInAt  DateTime? @map("checked_in_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([city])
  @@index([status])
  @@map("caravans")
}
